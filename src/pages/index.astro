---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Astro + Tailwind">
  <main class="min-h-screen flex items-center justify-center">
    <div class="text-center">
      <h1 class="text-5xl font-bold text-indigo-600 mb-4">
        Astro + Tailwind CSS
      </h1>
      <p class="text-xl text-gray-600 mb-8">
        Dein Projekt ist bereit. Viel Spaß beim Entwickeln!
      </p>
      <a
        href="https://docs.astro.build"
        class="inline-block bg-indigo-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-indigo-700 transition-colors"
      >
        Astro Docs
      </a>
    </div>
  </main>
</Layout>

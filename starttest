<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Induktionsgesetz & Lenz'sche Regel — 11NP Physik</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
  <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
  <script>
    window.MathJax = {
      tex: { inlineMath: [['\\(','\\)'], ['$','$']] },
      options: { skipHtmlTags: ['script','noscript','style','textarea','pre'] }
    };
  </script>
  <style>
    :root {
      --bg:      #070b16;
      --bg2:     #0d1426;
      --bg3:     #101828;
      --card:    #0c1424;
      --border:  #1a2840;
      --accent:  #00c8ff;
      --accent2: #ffb300;
      --accent3: #00e898;
      --red:     #ff4560;
      --text:    #b8ccE8;
      --dim:     #5a7a9a;
      --white:   #ffffff;
      --g1: #3b82f6;
      --g2: #a855f7;
      --g3: #22c55e;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{
      font-family:'Rajdhani',sans-serif;
      font-size:17px;line-height:1.65;
      background:var(--bg);color:var(--text);
      min-height:100vh;
    }
    body::before{
      content:'';position:fixed;inset:0;
      background-image:
        linear-gradient(rgba(0,200,255,.025) 1px,transparent 1px),
        linear-gradient(90deg,rgba(0,200,255,.025) 1px,transparent 1px);
      background-size:48px 48px;
      pointer-events:none;z-index:0;
    }

    /* ── HEADER ── */
    header{
      position:relative;z-index:10;
      padding:2rem 2rem 1.2rem;
      border-bottom:1px solid var(--border);
      background:linear-gradient(180deg,rgba(0,200,255,.06) 0%,transparent 100%);
    }
    .header-tag{
      font-family:'JetBrains Mono',monospace;
      font-size:.7rem;letter-spacing:.22em;
      color:var(--accent);text-transform:uppercase;margin-bottom:.5rem;
    }
    header h1{
      font-family:'Orbitron',monospace;font-weight:900;
      font-size:clamp(1.3rem,4vw,2.1rem);
      color:var(--white);letter-spacing:.04em;
    }
    header h1 em{color:var(--accent);font-style:normal}
    .header-sub{margin-top:.4rem;color:var(--dim);font-size:.9rem}

    /* ── PHASE BAR ── */
    .phase-bar{
      display:flex;gap:.4rem;
      padding:.8rem 2rem;
      border-bottom:1px solid var(--border);
      background:var(--bg2);
      position:sticky;top:0;z-index:100;
      overflow-x:auto;flex-shrink:0;
    }
    .phase-dot{
      display:flex;align-items:center;gap:.5rem;
      padding:.4rem .9rem;border-radius:3px;
      border:1px solid var(--border);
      cursor:pointer;transition:all .18s;
      white-space:nowrap;
      font-family:'Rajdhani',sans-serif;font-weight:700;font-size:.85rem;
      color:var(--dim);background:transparent;
    }
    .phase-dot.active{border-color:var(--accent);color:var(--accent);background:rgba(0,200,255,.07);box-shadow:0 0 14px rgba(0,200,255,.15)}
    .phase-dot.done{border-color:var(--accent3);color:var(--accent3)}

    /* ── MAIN ── */
    main{position:relative;z-index:1;max-width:920px;margin:0 auto;padding:2rem}

    .phase{display:none}
    .phase.active{display:block;animation:fadeUp .35s ease}
    @keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}

    /* ── TYPOGRAPHY ── */
    .phase-title{
      font-family:'Orbitron',monospace;font-weight:700;
      font-size:1.45rem;color:var(--white);margin-bottom:.25rem;
    }
    .phase-subtitle{
      font-family:'JetBrains Mono',monospace;
      font-size:.75rem;letter-spacing:.06em;
      color:var(--dim);margin-bottom:2rem;
    }

    /* ── CARDS ── */
    .card{
      background:var(--card);border:1px solid var(--border);
      border-radius:4px;padding:1.5rem;margin-bottom:1.5rem;
      position:relative;overflow:hidden;
    }
    .card::before{
      content:'';position:absolute;top:0;left:0;right:0;height:2px;
      background:linear-gradient(90deg,var(--accent),transparent);
    }
    .card.g1::before{background:linear-gradient(90deg,var(--g1),transparent)}
    .card.g2::before{background:linear-gradient(90deg,var(--g2),transparent)}
    .card.g3::before{background:linear-gradient(90deg,var(--g3),transparent)}

    .card h2{
      font-family:'Orbitron',monospace;font-size:.9rem;font-weight:700;
      color:var(--accent);margin-bottom:1rem;letter-spacing:.07em;
    }
    .card p{margin-bottom:.65rem}
    .card p:last-child{margin-bottom:0}

    strong.w{color:var(--white);font-weight:700}
    .a1{color:var(--accent)}
    .a2{color:var(--accent2)}
    .a3{color:var(--accent3)}

    /* ── FORMULA BOX ── */
    .formula-box{
      background:rgba(0,200,255,.05);
      border:1px solid rgba(0,200,255,.18);
      border-radius:4px;padding:1rem 1.5rem;margin:1rem 0;
      text-align:center;font-size:1.05rem;overflow-x:auto;
    }

    /* ── STEPS ── */
    .steps{
      display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));
      gap:1rem;margin:1.2rem 0;
    }
    .step{
      background:var(--bg3);border:1px solid var(--border);
      border-radius:4px;padding:1rem;text-align:center;
    }
    .step-num{
      font-family:'Orbitron',monospace;font-size:1.6rem;font-weight:900;
      color:var(--accent);display:block;margin-bottom:.4rem;
    }
    .step-title{font-weight:700;color:var(--white);font-size:.95rem;margin-bottom:.3rem}
    .step-desc{font-size:.82rem;color:var(--dim)}

    /* ── CALLOUTS ── */
    .callout{
      padding:1rem 1.4rem;border-radius:0 4px 4px 0;margin:1rem 0;
    }
    .callout.amber{background:rgba(255,179,0,.06);border-left:3px solid var(--accent2)}
    .callout.green{background:rgba(0,232,152,.06);border-left:3px solid var(--accent3)}
    .callout.blue{background:rgba(0,200,255,.06);border-left:3px solid var(--accent)}

    /* ── PARAM TABLE ── */
    .param-table{
      width:100%;border-collapse:collapse;margin:1rem 0;
      font-family:'JetBrains Mono',monospace;font-size:.83rem;
    }
    .param-table th{
      background:var(--bg3);padding:.5rem .9rem;
      border:1px solid var(--border);color:var(--dim);
      font-weight:400;letter-spacing:.04em;text-align:left;
    }
    .param-table td{
      padding:.5rem .9rem;border:1px solid var(--border);
      color:var(--white);font-weight:700;
    }

    /* ── GROUP TABS ── */
    .group-tabs{display:flex;gap:.5rem;margin-bottom:1rem;flex-wrap:wrap}
    .group-tab{
      padding:.45rem 1rem;border:1px solid var(--border);
      background:transparent;border-radius:3px;cursor:pointer;
      font-family:'Rajdhani',sans-serif;font-weight:700;font-size:.88rem;
      transition:all .18s;color:var(--dim);
    }
    .group-tab.g1.active{border-color:var(--g1);color:var(--g1);background:rgba(59,130,246,.1)}
    .group-tab.g2.active{border-color:var(--g2);color:var(--g2);background:rgba(168,85,247,.1)}
    .group-tab.g3.active{border-color:var(--g3);color:var(--g3);background:rgba(34,197,94,.1)}

    .group-content{display:none}
    .group-content.active{display:block;animation:fadeUp .25s ease}

    /* ── CHECKLIST ── */
    .checklist{list-style:none;display:flex;flex-direction:column;gap:.8rem}
    .checklist li{display:flex;align-items:flex-start;gap:.9rem}
    .check-badge{
      font-family:'Orbitron',monospace;font-size:.7rem;font-weight:700;
      color:var(--accent2);background:rgba(255,179,0,.1);
      border:1px solid rgba(255,179,0,.3);border-radius:3px;
      padding:.15rem .5rem;flex-shrink:0;margin-top:.15rem;
    }

    /* ── SOLUTION TOGGLE ── */
    .sol-toggle{
      background:var(--bg3);border:1px dashed var(--border);
      border-radius:4px 4px 0 0;padding:.8rem 1.2rem;
      cursor:pointer;display:flex;justify-content:space-between;
      align-items:center;margin-top:1rem;
      font-weight:700;font-size:.88rem;color:var(--dim);
      transition:all .18s;user-select:none;
    }
    .sol-toggle:hover{border-color:var(--accent);color:var(--accent)}
    .sol-body{
      display:none;background:var(--bg3);
      border:1px dashed var(--border);border-top:none;
      padding:1.2rem;border-radius:0 0 4px 4px;
    }
    .sol-body.open{display:block;animation:fadeUp .25s ease}
    .sol-body p{margin-bottom:.5rem}

    /* ── TIMER ── */
    .timer-wrap{
      display:flex;align-items:center;gap:1.5rem;
      padding:1.3rem 1.5rem;background:var(--bg3);
      border:1px solid var(--border);border-radius:4px;
      margin:1.5rem 0;flex-wrap:wrap;
    }
    .timer-display{
      font-family:'Orbitron',monospace;font-size:2.8rem;font-weight:900;
      color:var(--accent);letter-spacing:.1em;
      text-shadow:0 0 24px rgba(0,200,255,.35);min-width:160px;
    }
    .timer-display.warn{color:var(--accent2);text-shadow:0 0 24px rgba(255,179,0,.35)}
    .timer-display.danger{color:var(--red);text-shadow:0 0 24px rgba(255,69,96,.35);animation:blink 1s infinite}
    @keyframes blink{0%,100%{opacity:1}50%{opacity:.55}}

    .timer-controls{display:flex;flex-direction:column;gap:.6rem}
    .preset-row{display:flex;gap:.4rem;flex-wrap:wrap}
    .btn-row{display:flex;gap:.5rem;flex-wrap:wrap}

    /* ── BUTTONS ── */
    .btn{
      padding:.45rem 1.1rem;border:1px solid var(--accent);
      border-radius:3px;background:transparent;color:var(--accent);
      font-family:'Rajdhani',sans-serif;font-weight:700;font-size:.88rem;
      cursor:pointer;transition:all .18s;letter-spacing:.04em;
    }
    .btn:hover{background:rgba(0,200,255,.1);box-shadow:0 0 12px rgba(0,200,255,.2)}
    .btn.muted{border-color:var(--border);color:var(--dim)}
    .btn.muted:hover{border-color:var(--dim);color:var(--text)}

    .preset-btn{
      padding:.28rem .65rem;border:1px solid var(--border);
      border-radius:3px;background:transparent;
      font-family:'JetBrains Mono',monospace;font-size:.78rem;
      color:var(--dim);cursor:pointer;transition:all .18s;
    }
    .preset-btn:hover,.preset-btn.sel{border-color:var(--accent2);color:var(--accent2)}

    /* ── SIMULATION ── */
    .sim-wrap{
      background:var(--bg3);border:1px solid var(--border);
      border-radius:4px;padding:1.5rem;margin:1.5rem 0;
    }
    .sim-wrap h2{
      font-family:'Orbitron',monospace;font-size:.9rem;font-weight:700;
      color:var(--accent);margin-bottom:1rem;letter-spacing:.07em;
    }
    canvas{
      width:100%;display:block;border-radius:3px;background:#040810;
    }
    .sim-sliders{
      display:flex;gap:1rem;margin-top:1rem;flex-wrap:wrap;
    }
    .slider-group{
      display:flex;flex-direction:column;gap:.25rem;flex:1;min-width:140px;
    }
    .slider-label{
      font-family:'JetBrains Mono',monospace;font-size:.78rem;color:var(--dim);
    }
    .slider-label span{color:var(--accent);font-weight:700}
    input[type=range]{width:100%;accent-color:var(--accent)}

    .sim-group-row{display:flex;gap:.5rem;margin-bottom:1rem;flex-wrap:wrap}

    /* ── KEY INSIGHT ── */
    .insight{
      background:rgba(0,200,255,.05);
      border:1px solid rgba(0,200,255,.2);
      border-radius:4px;padding:1.2rem 1.5rem;margin:1rem 0;
    }
    .insight-head{
      font-family:'Orbitron',monospace;font-size:.75rem;
      color:var(--accent);margin-bottom:.5rem;letter-spacing:.12em;
    }

    /* ── EXIT TICKET ── */
    .exit-grid{display:flex;flex-direction:column;gap:1rem;margin-top:1rem}
    .exit-q{
      background:var(--bg3);border:1px solid var(--border);
      border-radius:4px;padding:1.2rem;
      display:flex;gap:1rem;align-items:flex-start;
    }
    .exit-num{
      font-family:'Orbitron',monospace;font-weight:900;font-size:1.6rem;
      color:var(--accent);flex-shrink:0;line-height:1;
    }

    /* ── NAV ── */
    .nav-row{
      display:flex;justify-content:space-between;align-items:center;
      margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--border);
    }

    /* ── LENZ CANVAS ── */
    #lenzCanvas{background:#040810;border-radius:3px;cursor:pointer}

    ::-webkit-scrollbar{width:5px;height:5px}
    ::-webkit-scrollbar-track{background:var(--bg)}
    ::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}

    @media(max-width:600px){
      main{padding:1rem}
      .timer-display{font-size:2rem}
      header h1{font-size:1.2rem}
    }
  </style>
</head>
<body>

<header>
  <div class="header-tag">⚡ 11NP Physik · Elektromagnetismus</div>
  <h1>⚡ <em>Induktionsgesetz</em> &amp; Lenz'sche Regel</h1>
  <div class="header-sub">Selbstinduktion einer Spule · Vertiefung &amp; Klausurvorbereitung | 11NP Physik</div>
</header>

<nav class="phase-bar" id="phaseBar">
  <button class="phase-dot active" onclick="goTo(0)">① Einstieg</button>
  <button class="phase-dot"        onclick="goTo(1)">② Ingenieursaufgabe</button>
  <button class="phase-dot"        onclick="goTo(2)">③ Ergebnisse &amp; Simulation</button>
  <button class="phase-dot"        onclick="goTo(3)">④ Klausurvorbereitung</button>
</nav>

<main>

<!-- ══════════════════════════════════════════ PHASE 1 ══ -->
<section class="phase active" id="p0">
  <div class="phase-title">⚡ Einstieg</div>
  <div class="phase-subtitle">// WARM-UP · GRUNDLAGEN AKTIVIEREN</div>

  <div class="card">
    <h2>🧲 DAS KLASSISCHE EXPERIMENT</h2>
    <p>Ein Stabmagnet wird in eine Spule geschoben. Am Galvanometer zeigt sich ein Ausschlag — obwohl die Spule <strong class="w">nirgends an einer Spannungsquelle hängt</strong>.</p>
    <div class="steps">
      <div class="step">
        <span class="step-num">1</span>
        <div class="step-title">Nähern</div>
        <div class="step-desc">Zeiger schlägt aus → Spannung entsteht</div>
      </div>
      <div class="step">
        <span class="step-num">2</span>
        <div class="step-title">Halten</div>
        <div class="step-desc">Zeiger auf null → kein Strom</div>
      </div>
      <div class="step">
        <span class="step-num">3</span>
        <div class="step-title">Entfernen</div>
        <div class="step-desc">Zeiger schlägt <em>entgegengesetzt</em> aus</div>
      </div>
    </div>
    <div class="formula-box">
      \[ U_\text{ind} = -N \cdot \frac{\Delta \Phi}{\Delta t} = -N \cdot A \cdot \frac{\Delta B}{\Delta t} \]
    </div>
    <p class="a3" style="font-weight:700">→ Entscheidend ist die <em>Änderung</em> des Flusses, nicht sein absoluter Wert!</p>
  </div>

  <div class="card">
    <h2>🔄 LENZ'SCHE REGEL — INTERAKTIV</h2>
    <p>Der Induktionsstrom wirkt stets seiner Ursache <strong class="w">entgegen</strong>.</p>
    <div class="callout amber" style="margin-bottom:1rem">
      <strong class="a2">Merkhilfe:</strong> „Induktion ist faul — sie wehrt sich gegen jede Änderung."<br>
      Wächst \(B\) → Induktionsstrom baut <em>Gegenfeld</em> auf.<br>
      Sinkt \(B\)&nbsp;&nbsp; → Induktionsstrom <em>hält das Feld aufrecht</em>.
    </div>
    <canvas id="lenzCanvas" height="190"></canvas>
    <div style="display:flex;gap:.5rem;margin-top:.8rem;flex-wrap:wrap">
      <button class="btn" onclick="lenzPlay('approach')">▶ Nähern</button>
      <button class="btn muted" onclick="lenzPlay('retreat')">▶ Entfernen</button>
      <button class="btn muted" onclick="lenzStop()">↺ Reset</button>
    </div>
  </div>

  <div class="card">
    <h2>⚡ SELBSTINDUKTION</h2>
    <p>Ändert sich der Strom <em>durch die Spule selbst</em>, erzeugt sie eine Gegenspannung (Lenz!):</p>
    <div class="formula-box">
      \[ U_L = -L \cdot \frac{\Delta I}{\Delta t} \]
    </div>
    <p>Die <strong class="w">Induktivität</strong> \(L\) (Einheit: Henry, H) gibt an, wie stark eine Spule Stromänderungen bremst.</p>
    <div class="callout green">
      <strong class="a3">RL-Kreis — Zeitkonstante \(\tau\):</strong><br>
      \(\tau = L/R\) — nach einer Zeitkonstante ist der Strom auf <strong>63 %</strong> seines Endwerts gestiegen.
      \[ I(t) = \frac{U_0}{R}\!\left(1 - e^{-t/\tau}\right) \qquad U_L(t) = U_0 \cdot e^{-t/\tau} \]
    </div>
  </div>

  <div class="card">
    <h2>💭 DENKANSTOSS</h2>
    <p>In einem Aufzug-Sicherheitssystem wird beim Stromausfall ein RL-Kreis aktiviert, der die Motorbremse kontrolliert entlädt — zu schnell würde die Bremse blockieren, zu langsam wäre gefährlich.</p>
    <div class="callout blue">
      <strong class="a1">Warum?</strong> Die Spule speichert Energie: \(W_L = \tfrac{1}{2}LI^2\).<br>
      Diese Energie kann nicht „augenblicklich" verschwinden — die Lenz'sche Regel erzwingt eine <em>kontrollierte</em> Abgabe.
    </div>
    <p>→ Genau das analysieren Sie jetzt als Ingenieur/in!</p>
  </div>

  <div class="nav-row">
    <span></span>
    <button class="btn" onclick="goTo(1)">Weiter → Ingenieursaufgabe ⚙️</button>
  </div>
</section>

<!-- ══════════════════════════════════════════ PHASE 2 ══ -->
<section class="phase" id="p1">
  <div class="phase-title">⚙️ Ingenieursaufgabe</div>
  <div class="phase-subtitle">// GRUPPENARBEIT · RL-BREMSKREIS ANALYSIEREN</div>

  <div class="card">
    <h2>📋 IHR AUFTRAG</h2>
    <p>In einer Fertigungsanlage werden <strong class="w">RL-Bremskreise</strong> eingesetzt, um rotierende Maschinenteile bei Not-Aus kontrolliert zu stoppen. Zum Zeitpunkt \(t = 0\) wird die Spannung \(U_0\) eingeschaltet.</p>
    <div class="callout green">
      <strong class="a3">Aufgabe:</strong> Analysieren Sie das Einschwingverhalten des Bremskreises Ihrer Gruppe. Erstellen Sie ein technisches Gutachten mit allen Berechnungen und einer physikalischen Begründung.
    </div>
  </div>

  <div class="card">
    <h2>📐 SCHALTUNG UND FORMELN</h2>
    <p>RL-Reihenschaltung: Ohmscher Widerstand \(R\), Induktivität \(L\), Versorgungsspannung \(U_0\).</p>
    <div class="formula-box">
      \[
        \tau = \frac{L}{R} \qquad
        I(t) = \frac{U_0}{R}\!\left(1 - e^{-t/\tau}\right) \qquad
        U_L(t) = U_0\,e^{-t/\tau}
      \]
      \[
        W_L = \tfrac{1}{2}\,L\,I_\text{max}^2 \qquad
        U_\text{ind} = N \cdot A \cdot \frac{\Delta B}{\Delta t}
      \]
    </div>
  </div>

  <!-- GROUP TABS -->
  <div class="group-tabs">
    <button class="group-tab g1 active" onclick="switchGroup('grp', 0)">🔵 Gruppe 1</button>
    <button class="group-tab g2"        onclick="switchGroup('grp', 1)">🟣 Gruppe 2</button>
    <button class="group-tab g3"        onclick="switchGroup('grp', 2)">🟢 Gruppe 3</button>
  </div>

  <div class="group-content active" id="grp-0">
    <div class="card g1">
      <h2>🔵 GRUPPE 1 — BREMSSPULE ALPHA</h2>
      <table class="param-table">
        <tr><th>Größe</th><th>Wert</th><th>Bedeutung</th></tr>
        <tr><td>\(U_0\)</td><td>24 V</td><td>Versorgungsspannung</td></tr>
        <tr><td>\(R\)</td><td>12 Ω</td><td>Ohmscher Widerstand</td></tr>
        <tr><td>\(L\)</td><td>0,60 H</td><td>Induktivität</td></tr>
        <tr><td>\(N\)</td><td>500</td><td>Windungszahl</td></tr>
        <tr><td>\(A\)</td><td>20 cm²</td><td>Spulenquerschnitt</td></tr>
        <tr><td>\(\Delta B/\Delta t\)</td><td>5,0 T/s</td><td>Änderungsrate des B-Feldes</td></tr>
      </table>
    </div>
  </div>

  <div class="group-content" id="grp-1">
    <div class="card g2">
      <h2>🟣 GRUPPE 2 — BREMSSPULE BETA</h2>
      <table class="param-table">
        <tr><th>Größe</th><th>Wert</th><th>Bedeutung</th></tr>
        <tr><td>\(U_0\)</td><td>36 V</td><td>Versorgungsspannung</td></tr>
        <tr><td>\(R\)</td><td>18 Ω</td><td>Ohmscher Widerstand</td></tr>
        <tr><td>\(L\)</td><td>0,90 H</td><td>Induktivität</td></tr>
        <tr><td>\(N\)</td><td>800</td><td>Windungszahl</td></tr>

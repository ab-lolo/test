<script>
/* ─────────────────────────── NAVIGATION ─────────────────────────── */
function goTo(n) {
  document.querySelectorAll('.phase').forEach((p, i) => p.classList.toggle('active', i === n));
  document.querySelectorAll('.phase-dot').forEach((d, i) => {
    d.classList.remove('active','done');
    if (i === n) d.classList.add('active');
    if (i < n)  d.classList.add('done');
  });
  window.scrollTo({ top: 0, behavior: 'smooth' });
  if (n === 2) { setTimeout(initSim, 100); }
}

/* ─────────────────────────── GROUPS ─────────────────────────── */
function switchGroup(prefix, n) {
  const section = prefix === 'grp' ? '#p1' : '#p2';
  document.querySelectorAll(`${section} .group-content`).forEach((g, i) => g.classList.toggle('active', i === n));
  document.querySelectorAll(`${section} .group-tab`).forEach((t, i) => t.classList.toggle('active', i === n));
  if (window.MathJax) MathJax.typesetPromise();
}

/* ─────────────────────────── SOLUTION TOGGLE ─────────────────────────── */
function toggleSol(btn) {
  const body = btn.nextElementSibling;
  body.classList.toggle('open');
  btn.querySelector('span').textContent = body.classList.contains('open') ? '▲' : '▼';
  if (window.MathJax) MathJax.typesetPromise();
}

/* ─────────────────────────── TIMER ─────────────────────────── */
let timerSec = 35 * 60, timerOn = false, timerIv = null;

function setTimer(m, el) {
  timerSec = m * 60;
  if (timerOn) { clearInterval(timerIv); timerOn = false; document.getElementById('tBtn').textContent = '▶ Start'; }
  document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('sel'));
  if (el) el.classList.add('sel');
  renderTimer();
}

function toggleTimer() {
  if (timerOn) {
    clearInterval(timerIv); timerOn = false;
    document.getElementById('tBtn').textContent = '▶ Start';
  } else {
    timerOn = true;
    document.getElementById('tBtn').textContent = '⏸ Pause';
    timerIv = setInterval(() => { timerSec--; renderTimer(); if (timerSec <= 0) { clearInterval(timerIv); timerOn = false; document.getElementById('tBtn').textContent = '▶ Start'; }}, 1000);
  }
}

function resetTimer() {
  clearInterval(timerIv); timerOn = false; timerSec = 35 * 60;
  document.getElementById('tBtn').textContent = '▶ Start';
  renderTimer();
}

function renderTimer() {
  const abs = Math.abs(timerSec);
  const m = String(Math.floor(abs/60)).padStart(2,'0');
  const s = String(abs%60).padStart(2,'0');
  const d = document.getElementById('timerDisplay');
  d.textContent = (timerSec < 0 ? '-' : '') + m + ':' + s;
  d.className = 'timer-display';
  if (timerSec < 300 && timerSec > 0) d.classList.add('warn');
  if (timerSec <= 0) d.classList.add('danger');
}

/* ─────────────────────────── LENZ ANIMATION ─────────────────────────── */
const lc = document.getElementById('lenzCanvas');
const lx = lc.getContext('2d');
let lDir = null, lT = 0, lAF = null;

function sizeLenz() {
  lc.width = lc.offsetWidth || 600;
  lc.height = 190;
  drawLenz();
}

function lenzPlay(dir) { lDir = dir; lT = 0; cancelAnimationFrame(lAF); stepLenz(); }
function lenzStop() { lDir = null; lT = 0; cancelAnimationFrame(lAF); drawLenz(); }

function stepLenz() {
  lT = Math.min(lT + 0.018, 1.4);
  drawLenz();
  if (lT < 1.4) lAF = requestAnimationFrame(stepLenz);
}

function drawLenz() {
  const W = lc.width, H = lc.height;
  lx.clearRect(0, 0, W, H);
  lx.fillStyle = '#040810'; lx.fillRect(0, 0, W, H);

  const cx = W * 0.68, cy = H * 0.5, cW = 70, cH = 44;

  // Spule — Windungen
  lx.strokeStyle = '#00c8ff'; lx.lineWidth = 2;
  for (let i = 0; i <= 4; i++) {
    const ex = cx - cW/2 + i * cW/4;
    lx.beginPath(); lx.ellipse(ex, cy, 7, cH/2, 0, 0, Math.PI*2); lx.stroke();
  }
  // Kern
  lx.fillStyle = '#162035';
  lx.fillRect(cx - cW/2 - 4, cy - 5, cW+8, 10);

  // Galvanometer
  const gx = cx, gy = cy + cH/2 + 30, gr = 18;
  lx.beginPath(); lx.arc(gx, gy, gr, 0, Math.PI*2);
  lx.strokeStyle = '#1e2d50'; lx.lineWidth = 1.5; lx.stroke();
  lx.fillStyle = '#0c1424'; lx.fill();
  lx.fillStyle = '#5a7a9a'; lx.font = '10px JetBrains Mono,monospace'; lx.textAlign = 'center';
  lx.fillText('G', gx, gy + 4);

  // Galvanometer needle
  if (lDir && lT > 0.3) {
    const deflect = Math.min((lT - 0.3) * 2.5, 1);
    const angle = lDir === 'approach' ? -deflect * 0.7 : deflect * 0.7;
    lx.save(); lx.translate(gx, gy);
    lx.rotate(angle);
    lx.strokeStyle = '#ff4560'; lx.lineWidth = 1.5;
    lx.beginPath(); lx.moveTo(0, 0); lx.lineTo(0, -gr + 4); lx.stroke();
    lx.restore();
  }

  // Magnet position
  let mx;
  const startX = W * 0.1, endX = cx - cW/2 - 20;
  if (lDir === 'approach') mx = startX + lT/1.4 * (endX - startX);
  else if (lDir === 'retreat') mx = endX - lT/1.4 * (endX - startX) * 0.8;
  else mx = startX;

  // N pole
  lx.fillStyle = '#c0233a';
  lx.fillRect(mx, cy - 17, 30, 34);
  lx.fillStyle = '#fff'; lx.font = 'bold 13px Orbitron,monospace'; lx.textAlign = 'center';
  lx.fillText('N', mx + 15, cy + 5);
  // S pole
  lx.fillStyle = '#1d3a8a';
  lx.fillRect(mx - 28, cy - 17, 28, 34);
  lx.fillStyle = '#fff';
  lx.fillText('S', mx - 14, cy + 5);

  // Field lines
  if (lDir && lT > 0) {
    const alpha = Math.min(lT * 2, 0.55);
    lx.globalAlpha = alpha;
    lx.strokeStyle = '#ff6080'; lx.lineWidth = 1.2; lx.setLineDash([5, 5]);
    for (let dy = -12; dy <= 12; dy += 12) {
      lx.beginPath(); lx.moveTo(mx + 30, cy + dy); lx.lineTo(cx - cW/2 - 2, cy + dy); lx.stroke();
    }
    lx.setLineDash([]); lx.globalAlpha = 1;

    // Induced current arrow + label
    if (lT > 0.4) {
      const fa = Math.min((lT - 0.4) * 3, 1);
      lx.globalAlpha = fa;
      const col = lDir === 'approach' ? '#00e898' : '#ffb300';
      lx.strokeStyle = col; lx.fillStyle = col; lx.lineWidth = 2;
      const arcDir = lDir === 'approach';
      lx.beginPath();
      lx.arc(cx, cy - cH/2 - 14, 11, 0.4, Math.PI*2 - 0.4, !arcDir);
      lx.stroke();
      // Arrowhead
      const aAngle = arcDir ? Math.PI*2 - 0.4 : 0.4;
      const ax = cx + 11 * Math.cos(aAngle), ay = cy - cH/2 - 14 + 11 * Math.sin(aAngle);
      lx.beginPath(); lx.arc(ax, ay, 3, 0, Math.PI*2); lx.fill();

      lx.font = '10px Rajdhani,sans-serif'; lx.textAlign = 'center';
      const label = lDir === 'approach' ? 'I ⟳ (gegen ↑B)' : 'I ⟲ (hält ↓B)';
      lx.fillText(label, cx, cy - cH/2 - 30);
      lx.globalAlpha = 1;
    }
  }

  // Labels
  lx.fillStyle = '#3a5070'; lx.font = '10px Rajdhani,sans-serif'; lx.textAlign = 'center';
  lx.fillText('Spule', cx, cy + cH/2 + 12);
  lx.fillText('Galvanometer', gx, gy + gr + 12);
}

window.addEventListener('load', () => { sizeLenz(); drawLenz(); });
window.addEventListener('resize', () => { sizeLenz(); if (simReady) { resizeSim(); simDraw(simT); } });

/* ─────────────────────────── RL SIMULATION ─────────────────────────── */
const sc = document.getElementById('simCanvas');
const sx = sc.getContext('2d');
let simReady = false, simRunning = false, simT = 0, simAF = null;

const groupPresets = [
  { L: 0.6, R: 12, U: 24 },
  { L: 0.9, R: 18, U: 36 },
  { L: 0.3, R:  6, U: 12 },
];

function initSim() {
  if (simReady) return;
  simReady = true;
  resizeSim();
  simDraw(0);
}

function resizeSim() {
  sc.width = sc.offsetWidth || 700;
  sc.height = 230;
}

function getP() {
  return {
    L: +document.getElementById('lSlider').value,
    R: +document.getElementById('rSlider').value,
    U: +document.getElementById('uSlider').value,
  };
}

function simUpdate() {
  document.getElementById('lVal').textContent = (+document.getElementById('lSlider').value).toFixed(2);
  document.getElementById('rVal').textContent = document.getElementById('rSlider').value;
  document.getElementById('uVal').textContent = document.getElementById('uSlider').value;
  if (!simRunning) simDraw(simT);
}

function simLoadGroup(n) {
  const p = groupPresets[n];
  document.getElementById('lSlider').value = p.L;
  document.getElementById('rSlider').value = p.R;
  document.getElementById('uSlider').value = p.U;
  simUpdate();
}

function simToggle() {
  if (simRunning) {
    cancelAnimationFrame(simAF); simRunning = false;
    document.getElementById('simBtn').textContent = '▶ Simulation starten';
  } else {
    simT = 0; simRunning = true;
    document.getElementById('simBtn').textContent = '⏸ Pause';
    simStep();
  }
}

function simReset() {
  cancelAnimationFrame(simAF); simRunning = false; simT = 0;
  document.getElementById('simBtn').textContent = '▶ Simulation starten';
  simDraw(0);
}

function simStep() {
  const p = getP(), tau = p.L / p.R;
  simT += tau * 0.012;
  simDraw(simT);
  if (simT < 5.2 * tau) simAF = requestAnimationFrame(simStep);
  else { simRunning = false; document.getElementById('simBtn').textContent = '▶ Simulation starten'; }
}

function simDraw(tNow) {
  const W = sc.width, H = sc.height;
  sx.clearRect(0, 0, W, H);
  sx.fillStyle = '#040810'; sx.fillRect(0, 0, W, H);

  const p = getP(), tau = p.L / p.R, Imax = p.U / p.R;
  const tMax = 5 * tau;
  const PL = 58, PR = 16, PT = 32, PB = 42;
  const pw = W - PL - PR, ph = H - PT - PB;

  // Grid
  sx.strokeStyle = '#152030'; sx.lineWidth = 1;
  for (let i = 0; i <= 5; i++) {
    const x = PL + i * pw / 5;
    sx.beginPath(); sx.moveTo(x, PT); sx.lineTo(x, PT + ph); sx.stroke();
    // x-axis label
    sx.fillStyle = '#3a5070'; sx.font = '9px JetBrains Mono,monospace'; sx.textAlign = 'center';
    const t = i * tMax / 5;
    sx.fillText(t.toFixed(3)+'s', x, PT + ph + 14);
  }
  for (let i = 0; i <= 4; i++) {
    const y = PT + i * ph / 4;
    sx.beginPath(); sx.moveTo(PL, y); sx.lineTo(PL + pw, y); sx.stroke();
  }

  // Tau marker
  const tauX = PL + (tau / tMax) * pw;
  sx.save(); sx.strokeStyle = '#ffb300'; sx.setLineDash([4,4]); sx.lineWidth = 1;
  sx.beginPath(); sx.moveTo(tauX, PT); sx.lineTo(tauX, PT+ph); sx.stroke();
  sx.restore();
  sx.fillStyle = '#ffb300'; sx.font = '10px Orbitron,monospace'; sx.textAlign = 'center';
  sx.fillText('τ', tauX, PT - 10);

  // Axes
  sx.strokeStyle = '#253550'; sx.lineWidth = 1.5;
  sx.beginPath(); sx.moveTo(PL, PT); sx.lineTo(PL, PT+ph+2); sx.stroke();
  sx.beginPath(); sx.moveTo(PL-2, PT+ph); sx.lineTo(PL+pw, PT+ph); sx.stroke();

  // Y labels
  sx.fillStyle = '#3a5070'; sx.font = '9px JetBrains Mono,monospace'; sx.textAlign = 'right';
  sx.fillText(Imax.toFixed(1)+'A', PL-4, PT+6);
  sx.fillText((Imax*0.5).toFixed(1)+'A', PL-4, PT+ph*0.5+4);
  sx.fillText('0', PL-4, PT+ph+4);

  // X axis arrow
  sx.fillStyle = '#3a5070'; sx.font = '10px Rajdhani,sans-serif'; sx.textAlign = 'left';
  sx.fillText('t →', PL+pw+4, PT+ph+4);

  // I(t) curve
  sx.beginPath(); sx.strokeStyle = '#00c8ff'; sx.lineWidth = 2.5;
  let first = true;
  for (let i = 0; i <= 600; i++) {
    const t = (i / 600) * tMax;
    if (t > tNow + 0.0001) break;
    const I = Imax * (1 - Math.exp(-t / tau));
    const x = PL + (t / tMax) * pw;
    const y = PT + ph - (I / Imax) * ph;
    first ? (sx.moveTo(x, y), first=false) : sx.lineTo(x, y);
  }
  sx.stroke();

  // U_L(t) curve (scaled to I scale via U_L/U0)
  sx.beginPath(); sx.strokeStyle = '#ffb300'; sx.lineWidth = 2; sx.setLineDash([6,3]);
  first = true;
  for (let i = 0; i <= 600; i++) {
    const t = (i / 600) * tMax;
    if (t > tNow + 0.0001) break;
    const UL_norm = Math.exp(-t / tau);  // scaled 0→1
    const x = PL + (t / tMax) * pw;
    const y = PT + ph - UL_norm * ph;
    first ? (sx.moveTo(x, y), first=false) : sx.lineTo(x, y);
  }
  sx.stroke(); sx.setLineDash([]);

  // Legend
  const ly = PT + 8;
  sx.fillStyle = '#00c8ff'; sx.fillRect(PL+12, ly, 18, 3);
  sx.fillStyle = '#b8cce8'; sx.font = '11px Rajdhani,sans-serif'; sx.textAlign = 'left';
  sx.fillText(`I(t)  →  Imax = ${Imax.toFixed(2)} A`, PL+36, ly+5);

  sx.fillStyle = '#ffb300'; sx.fillRect(PL+12, ly+16, 18, 3);
  sx.fillStyle = '#b8cce8';
  sx.fillText(`U_L(t)  →  τ = ${tau.toFixed(4)} s`, PL+36, ly+21);

  // Current dot
  if (tNow > 0 && tNow <= tMax) {
    const I_now = Imax * (1 - Math.exp(-tNow / tau));
    const dx = PL + (tNow / tMax) * pw;
    const dy = PT + ph - (I_now / Imax) * ph;
    sx.beginPath(); sx.arc(dx, dy, 5, 0, Math.PI*2);
    sx.fillStyle = '#00c8ff'; sx.fill();
    sx.strokeStyle = '#fff'; sx.lineWidth = 1.5; sx.stroke();
  }
}
